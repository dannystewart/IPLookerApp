{
  "folders": [
    {
      "path": "."
    },
    {
      "path": "../../polykit-swift"
    },
    {
      "path": "../../homebrew-apps"
    }
  ],
  "settings": {
    "editor.detectIndentation": false,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "files.exclude": {
      "**/*.xcodeproj": true,
      "**/.DS_Store": true,
      "**/.git": true,
      "**/.hg": true,
      "**/.plugin_symlinks": true,
      "**/.pytest_cache": true,
      "**/.svn": true,
      "**/.symlinks": true,
      "**/.vscode": true,
      "**/.windsurf": true,
      "**/__pycache__": true,
      "**/Assets.xcassets": true,
      "**/CVS": true,
      "**/flutter/ephemeral": true,
      "**/Flutter/ephemeral": true,
      "**/node_modules": true,
      "**/Thumbs.db": true,
      "*.code-workspace": true,
      "*.icon": true,
      "*.sh": true,
      ".claude": true,
      ".cursor": true,
      ".cursorindexingignore": true,
      ".github": true,
      ".gitignore": true,
      ".history": true,
      ".pre-commit-config.yaml": true,
      ".swiftpm": true,
      "ci_scripts": true,
      "env*": true,
      "Package.resolved": true,
      "releases": true,
      "venv": true,
      "WARP.md": true
    },
    "scopedCommits.scopes": [
      "agents",
      "auth",
      "cli",
      "config",
      "data",
      "network",
      "platform",
      "polybugs",
      "polylogs",
      "projects",
      "readme",
      "security",
      "state",
      "sync",
      "ui",
      "xdeploy",
      "xreturn",
      "polyhue"
    ],
    "search.exclude": {
      "Build": true,
      "Documentation/LiquidGlass": true
    },
    "swift.autoGenerateLaunchConfigurations": false,
    "swift.backgroundCompilation": false,
    "swift.buildPath": "./.build",
    "swift.swiftEnvironmentVariables": {}
  }
}
